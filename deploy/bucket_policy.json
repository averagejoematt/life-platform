{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadSite",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::matthew-life-platform/site/*"
    },
    {
      "Sid": "PublicReadBlog",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::matthew-life-platform/blog/*"
    },
    {
      "Sid": "ProtectDataFromDeployScripts",
      "Effect": "Deny",
      "Principal": {
        "AWS": "arn:aws:iam::205930651321:user/matthew-admin"
      },
      "Action": "s3:DeleteObject",
      "Resource": [
        "arn:aws:s3:::matthew-life-platform/raw/*",
        "arn:aws:s3:::matthew-life-platform/config/*",
        "arn:aws:s3:::matthew-life-platform/uploads/*",
        "arn:aws:s3:::matthew-life-platform/dashboard/*",
        "arn:aws:s3:::matthew-life-platform/exports/*",
        "arn:aws:s3:::matthew-life-platform/deploys/*",
        "arn:aws:s3:::matthew-life-platform/cloudtrail/*",
        "arn:aws:s3:::matthew-life-platform/imports/*"
      ]
    }
  ]
}

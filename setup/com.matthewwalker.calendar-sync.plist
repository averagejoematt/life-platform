<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.matthewwalker.calendar-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/matthewwalker/Documents/Claude/life-platform/setup/run_calendar_sync.sh</string>
    </array>

    <!-- Run every 4 hours (14400 seconds).
         Catches at least 2-3 windows per workday when the lid is open.
         Script is idempotent — multiple runs/day just overwrite the same record. -->
    <key>StartInterval</key>
    <integer>14400</integer>

    <!-- Also run immediately at login / Mac wake, catching any window missed
         while the lid was closed. -->
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/matthewwalker/Documents/Claude/life-platform/setup/calendar_sync_launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/matthewwalker/Documents/Claude/life-platform/setup/calendar_sync_launchd.log</string>
</dict>
</plist>

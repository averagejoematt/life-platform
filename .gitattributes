# Normalize line endings + mark binaries — keeps diffs clean across platforms.
* text=auto

*.py   text eol=lf
*.sh   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf
*.txt  text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.html text eol=lf

*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.zip  binary
*.gz   binary
*.pdf  binary

      "lambdas/platform_logger.py",
      "lambdas/ingestion_framework.py",
      "lambdas/ingestion_validator.py",
      "lambdas/item_size_guard.py",
      "lambdas/digest_utils.py",
      "lambdas/site_writer.py",
      "lambdas/secret_cache.py"
    ],
    "consumers": [
      "daily-brief", "weekly-digest", "monthly-digest",
      "nutrition-review", "wednesday-chronicle", "weekly-plate",
      "monday-compass", "anomaly-detector", "character-sheet-compute",
      "daily-metrics-compute", "daily-insight-compute",
      "adaptive-mode-compute", "hypothesis-engine", "dashboard-refresh",
      "weekly-correlation-compute"
    ]
  },

  "lambda_edge": {
    "_comment": "Lambda@Edge functions — deployed in us-east-1, manually managed outside CDK. NOT auto-deployed via CI/CD pipeline. Metrics aggregated to us-east-1 per AWS requirement.",
    "functions": {
      "lambdas/cf-auth/index.mjs": {
        "function": "life-platform-cf-auth",
        "region": "us-east-1",
        "cloudfront_distribution": "EM5NPX6NJN095",
        "protects": "dash.averagejoematt.com",
        "note": "Manually deployed — NOT CDK-managed. Lambda@Edge requires us-east-1 and cannot be deployed from us-west-2 CDK stacks. Secret: life-platform/cf-auth (must exist in us-east-1). Alarm: life-platform-cf-auth-errors (us-east-1 CloudWatch)."
      },
      "lambdas/site_api_lambda.py": {
        "function": "life-platform-site-api",
        "note": "CDK-managed (LifePlatformWeb stack). Read-only public API for averagejoematt.com. Reserved concurrency=20."
      }
    }
  },

  "email_subscriber": {
    "lambdas/email_subscriber_lambda.py": {
      "function": "email-subscriber",
      "handler": "email_subscriber_lambda.lambda_handler",
      "stack": "LifePlatformOperational",
      "note": "BS-03: subscribe/confirm/unsubscribe. DDB subscribers partition. SES double opt-in. No Function URL — wired to API Gateway /api/subscribe."
    }
  },

  "acwr_compute": {
    "lambdas/acwr_compute_lambda.py": {
      "function": "acwr-compute",
      "handler": "acwr_compute_lambda.lambda_handler",
      "stack": "LifePlatformCompute",
      "note": "BS-09: Whoop strain ACWR. Runs 9:55 AM PT daily. Writes to computed_metrics partition."
    }
  },

  "sleep_reconciler": {
    "lambdas/sleep_reconciler_lambda.py": {
      "function": "sleep-reconciler",
      "handler": "sleep_reconciler_lambda.lambda_handler",
      "stack": "LifePlatformCompute",
      "note": "BS-08: Unified Sleep Record — merges Whoop/Eight Sleep/Apple Health nightly. Runs 7:00 AM PT daily. Writes to sleep_unified partition."
    }
  },

  "circadian_compliance": {
    "lambdas/circadian_compliance_lambda.py": {
      "function": "circadian-compliance",
      "handler": "circadian_compliance_lambda.lambda_handler",
      "stack": "LifePlatformCompute",
      "note": "BS-SL2: Circadian Compliance Score — pre-sleep behavioral score (0-100). Runs 7:00 PM PT daily. Writes to circadian partition. Surfaces in Evening Nudge."
    }
  },

  "chronicle_email_sender": {
    "lambdas/chronicle_email_sender_lambda.py": {
      "function": "chronicle-email-sender",
      "handler": "chronicle_email_sender_lambda.lambda_handler",
      "stack": "LifePlatformEmail",
      "note": "BS-03: Delivers Chronicle installment to confirmed subscribers. Wed 8:10 AM PT. Viktor guard: no-op if no installment this week."
    }
  },


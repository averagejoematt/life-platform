  "version": "1.0.0",
  "description": "Canonical food vocabulary for the derived meal layer (ADR meal-grouping). Maps raw MacroFactor food names to canonical tokens. RULE: canonicalize spellings of the SAME food only \u2014 never merge distinct dishes (chicken_shawarma/butter_chicken/etc. stay separate; mongolian_beef is not beef_steak).",
  "roles": {
    "anchor": "meal core (defines a meal)",
    "base": "starch/carb base (can anchor a bowl when no protein present: oats)",
    "veg": "vegetable modifier",
    "fruit": "fruit modifier/snack",
    "nut_seed": "nut/seed modifier/snack",
    "fat": "added fat/oil modifier",
    "dairy": "milk/cheese modifier",
    "sauce": "sauce/condiment modifier",
    "treat": "dessert/treat modifier/snack",
    "snack_core": "defines a snack occasion (whey/smoothie/bar)",
    "beverage": "counted in totals, never a meal or snack card",
    "supplement": "non-food scaffold, counted, never a meal",
    "other": "unmatched fallback"
  },

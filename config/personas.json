    "purpose": "Canonical persona registry (CC-00). The single source of truth that reconciles the three historically-divergent coach name-spaces: config/coaches/*.json keys, the engine COACH_IDS, and the board_of_directors.json personas. A coach's public byline must provably be the coach that authored the data — this file is what makes that true.",
    "model": "distinct-but-linked: operational coaches are the 8 personas with a live coach_config_key + daily outputs; the broader Board (the_chair, narrators, real-expert inspirations, non-coach advisors) stays on /evidence/board/, cross-linked via board_persona_key.",
    "links": {
      "voice_specs": "config/coaches/<coach_config_key>.json",
      "board": "config/<user>/board_of_directors.json (member keys = board_persona_key)",
      "engine": "lambdas/coach/coach_computation_engine.py + coach_prediction_evaluator.py (COACH_IDS) and coach_narrative_orchestrator.py (ALL_COACH_IDS) — all must equal the operational coach ids",
      "credibility": "lambdas/intelligence_common.py COACH_IDS_ALL — must equal the operational short_ids"
    },
    "enforced_by": "tests/test_persona_registry.py (no orphans either direction)",
    "loader": "lambdas/persona_registry.py",
    "last_reviewed": "2026-06-13"
  },

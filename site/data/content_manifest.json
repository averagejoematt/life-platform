    "chronicle/posts/*": {
      "journey_sensitive": false,
      "sections": [
        { "type": "archive",          "element": "full post content",          "contains": "Historical narrative — dates, weights, context from time of publication. DO NOT retroactively edit." }
      ]
    },

    "journal/posts/*": {
      "journey_sensitive": false,
      "sections": [
        { "type": "archive",          "element": "full post content",          "contains": "Historical narrative — DO NOT retroactively edit." }
      ]
    }
  },

  "non_html": {

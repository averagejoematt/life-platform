{
  "_meta": {
    "purpose": "Inventory of journey-sensitive prose content across the site. When reframing the journey narrative, consult this file to find every location that needs a human editorial pass.",
    "updated": "2026-03-24",
    "categories": {
      "constant": "Value comes from site_constants.js — auto-updates",
      "api_driven": "Value comes from API/public_stats.json — auto-updates",
      "prose_with_facts": "Editorial paragraph with embedded facts — needs manual review when facts change",

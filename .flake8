[flake8]
max-line-length = 140
exclude =
    .git,
    __pycache__,
    deploy,
    backfill,
    patches,
    seeds,
    setup,
    handovers,
    datadrops,
    .github,
    venv,
    .venv
# E501: line too long (handled by max-line-length)
# W503: line break before binary operator (PEP 8 changed its mind)
# E402: module level import not at top of file (common in Lambda handlers)
# E741: ambiguous variable name (l, O, I) — too many false positives
extend-ignore = W503, E402, E741
per-file-ignores =
    # MCP tools files have long string literals in docstrings
    mcp/tools_*.py: E501
    # Lambda handlers often have long format strings
    lambdas/*_lambda.py: E501
